# 로컬 개발용 환경 변수 예시
# 실제 값은 .env 파일에 복사해서 채워 넣고, .env는 절대 커밋하지 말 것.

# Firebase Admin SDK 서비스 계정 키 (로컬 개발 시에만 필요)
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# 다운로드한 JSON 파일을 Backend/server/ 안에 두고 경로 지정
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# CORS 허용 도메인 (콤마로 구분)
# Flutter 앱은 모바일이라 CORS 필요 없지만, 웹/Swagger UI에서 호출할 때 필요
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# cron-job.org가 /tasks/check-expiry 호출할 때 헤더에 실어 보낼 비밀키
# (랜덤한 32자 이상 문자열 권장. PowerShell:  -join ((48..122) | %{[char]$_} | Get-Random -Count 32) )
# Render에서는 이 값을 Environment Variable로 주입.
CRON_SECRET=replace-me-with-random-32chars

# Render 배포 시에는 .env 대신 대시보드의 Environment Variables 사용
# 로컬에서만 .env 활용
